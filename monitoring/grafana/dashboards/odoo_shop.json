{
  "title": "Odoo Shop",
  "uid": "odoo_shop",
  "tags": ["odoo", "rust"],
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "title": "CPU",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]}
        }
      },
      "targets": [{ "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)" }]
    },
    {
      "title": "Memory",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]}
        }
      },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100" }]
    },
    {
      "title": "Load Average",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "none" }
      },
      "targets": [
        { "expr": "node_load1", "legendFormat": "1m" },
        { "expr": "node_load5", "legendFormat": "5m" },
        { "expr": "node_load15", "legendFormat": "15m" }
      ]
    },
    {
      "title": "CPU por proceso",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      },
      "targets": [
        { "expr": "rate(namedprocess_namegroup_cpu_seconds_total{mode=\"user\"}[1m]) * 100", "legendFormat": "{{groupname}}" }
      ]
    },
    {
      "title": "Memoria por proceso (RSS)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        { "expr": "namedprocess_namegroup_memory_bytes{memtype=\"resident\"}", "legendFormat": "{{groupname}}" }
      ]
    },
    {
      "title": "Rust — HTTP Requests Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "targets": [{
        "expr": "rate(axum_http_requests_total[1m])",
        "legendFormat": "{{method}} {{path}}"
      }]
    },
    {
      "title": "Rust — HTTP Error Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "targets": [{
        "expr": "rate(axum_http_requests_total{status=~\"5..\"}[1m])",
        "legendFormat": "5xx"
      }]
    },
    {
      "title": "Rust — HTTP Duration (p50 / p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(axum_http_requests_duration_seconds_bucket[1m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(axum_http_requests_duration_seconds_bucket[1m]))", "legendFormat": "p95" }
      ]
    },
    {
      "title": "Odoo — Active Users",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "odoo_users_total" }]
    },
    {
      "title": "Odoo — Published Products",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "odoo_products_total" }]
    },
    {
      "title": "Odoo — Unpublished",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed" }, "custom": { "color": "semi-dark-red" } } },
      "targets": [{ "expr": "odoo_products_unpublished" }]
    },
    {
      "title": "Odoo — No Stock",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed" }, "custom": { "color": "semi-dark-red" } } },
      "targets": [{ "expr": "odoo_products_no_stock" }]
    },
    {
      "title": "Odoo — Low Stock (\u226410)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed" }, "custom": { "color": "semi-dark-yellow" } } },
      "targets": [{ "expr": "odoo_products_low_stock" }]
    },
    {
      "title": "Odoo — Sync Duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [{
        "expr": "rate(odoo_sync_duration_seconds_sum[1m]) / rate(odoo_sync_duration_seconds_count[1m])",
        "legendFormat": "avg sync duration"
      }]
    }
  ]
}
